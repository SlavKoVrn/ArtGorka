        "/api/projects/{id}/check": {
            "post": {
                "tags": [
                    "Projects"
                ],
                "summary": "Check project availability",
                "description": "Checks if the project URL is accessible and returns status information",
                "operationId": "e6a7bce1fdd5971742a1ba29f8d767f2",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "Project ID",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Availability check completed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "required": [
                                        "success",
                                        "data"
                                    ],
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "required": [
                                                "project_id",
                                                "url",
                                                "status",
                                                "http_code",
                                                "response_time",
                                                "checked_at"
                                            ],
                                            "properties": {
                                                "project_id": {
                                                    "type": "integer",
                                                    "example": 9
                                                },
                                                "url": {
                                                    "type": "string",
                                                    "format": "uri",
                                                    "example": "https://yandex.ru"
                                                },
                                                "status": {
                                                    "type": "string",
                                                    "example": "available",
                                                    "enum": [
                                                        "available",
                                                        "unavailable"
                                                    ]
                                                },
                                                "http_code": {
                                                    "type": "integer",
                                                    "example": 200
                                                },
                                                "response_time": {
                                                    "type": "number",
                                                    "format": "float",
                                                    "example": 612.25
                                                },
                                                "checked_at": {
                                                    "type": "string",
                                                    "format": "date-time",
                                                    "example": "2026-03-06T12:06:53+00:00"
                                                }
                                            },
