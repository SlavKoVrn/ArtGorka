{
  "openapi": "3.0.0",
  "info": {
    "title": "REST API",
    "version": "srv 1.0",
    "description": "API for managing projects"
  },
  "tags": [
    {
      "name": "Projects",
      "description": "Project management endpoints"
    }
  ],
  "paths": {
    "/api/projects": {
      "get": {
        "tags": ["Projects"],
        "summary": "Get all projects",
        "description": "Retrieve a list of projects, optionally filtered by status",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Filter projects by status",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["development", "production", "maintenance", "archived"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of projects",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Project"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          }
        }
      },
      "post": {
        "tags": ["Projects"],
        "summary": "Create a new project",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Project created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
          "400": {
            "description": "Bad request - invalid input"
          }
        }
      }
    },
    "/api/projects/{id}": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "description": "Project ID",
          "required": true,
          "schema": {
            "type": "integer",
            "minimum": 1
          }
        }
      ],
      "get": {
        "tags": ["Projects"],
        "summary": "Get project by ID",
        "responses": {
          "200": {
            "description": "Project details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
          "404": {
            "description": "Project not found"
          }
        }
      },
      "put": {
        "tags": ["Projects"],
        "summary": "Update project",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Project updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Project"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "Project not found"
          }
        }
      },
      "delete": {
        "tags": ["Projects"],
        "summary": "Delete project",
        "responses": {
          "204": {
            "description": "Project deleted successfully"
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "Project not found"
          }
        }
      }
    },
    "/api/projects/{id}/check": {
      "post": {
        "tags": ["Projects"],
        "summary": "Check project health or validity",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Project ID",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Check completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "Project not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProjectInput": {
        "type": "object",
        "required": ["name", "url"],
        "properties": {
          "name": {
            "type": "string",
            "example": "Project name",
            "minLength": 1,
            "maxLength": 255
          },
          "url": {
            "type": "string",
            "format": "uri",
            "example": "https://yandex.ru"
          },
          "platform": {
            "type": "string",
            "example": "Bitrix",
            "enum": ["WordPress", "Bitrix", "Custom", "Other"]
          },
          "status": {
            "type": "string",
            "example": "production",
            "enum": ["development", "production", "maintenance", "archived"]
          },
          "description": {
            "type": "string",
            "example": "project description",
            "maxLength": 1000
          }
        }
      },
      "Project": {
        "type": "object",
        "allOf": [
          {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "example": 1,
                "readOnly": true
              },
              "created_at": {
                "type": "string",
                "format": "date-time",
                "example": "2026-03-05 14:22:00",
                "readOnly": true
              },
              "updated_at": {
                "type": "string",
                "format": "date-time",
                "example": "2026-03-05 14:22:00",
                "readOnly": true
              }
            }
          },
          {
            "$ref": "#/components/schemas/ProjectInput"
          }
        ]
      },
      "CheckResult": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolen",
            "enum": ["true", "false"],
            "example": "true"
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "project_id": {
                  "type": "integer",
                  "example": "1"
                },
                "url": {
                  "type": "uri",
                  "example": "http://yandex.ru"
                },
                "status": {
                  "type": "string",
                  "enum": ["available", "unavailable"],
                  "example": "request return status 200"
                },
                "http_code": {
                  "type": "string",
                  "enum": ["200", "400"],
                  "example": "200",
                  "description": "request return status"
                },
                "response_time": {
                  "type": "float",
                  "example": "98.27",
                  "description": "request time executed"
                },
                "checked_at": {
                  "type": "string",
                  "format": "date-time",
                  "example": "2026-03-05T13:53:33+00:00"
                }
              }
            }
          }
        }
      }
    }
  }
}