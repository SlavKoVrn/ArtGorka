                                                    "status": {
                                                        "type": "string",
                                                        "example": "production",
                                                        "enum": [
                                                            "development",
                                                            "production",
                                                            "maintenance",
                                                            "archived"
                                                        ]
                                                    },
                                                    "description": {
                                                        "type": "string",
                                                        "example": "Project description"
                                                    },
                                                    "created_at": {
                                                        "type": "string",
                                                        "format": "date-time",
                                                        "example": "2024-01-01 00:00:00"
                                                    },
                                                    "updated_at": {
                                                        "type": "string",
